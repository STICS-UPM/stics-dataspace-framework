{
  "@context": {
    "@vocab": "https://w3id.org/edc/v0.0.1/ns/",
    "daimo": "https://pionera.ai/edc/daimo#"
  },
  "@id": "provider~benchmark-text-linear-v1",
  "properties": {
    "name": "Benchmark Text Linear v1",
    "description": "Logistic-style text classifier service for benchmark comparison runs.",
    "version": "1.0.0",
    "contenttype": "application/json",
    "daimo:pipeline_tag": "text-classification",
    "daimo:task": ["text-classification"],
    "daimo:subtask": ["sentiment-analysis", "ticket-triage"],
    "daimo:algorithm": ["Logistic Regression", "Linear Classifier"],
    "daimo:license": "Apache-2.0",
    "daimo:tags": ["inference", "benchmark", "text", "classification"],
    "daimo:library_name": "custom-python",
    "daimo:library": ["custom-python", "scikit-learn"],
    "daimo:framework": ["FastAPI"],
    "daimo:software": ["Python 3.11"],
    "daimo:format": "json-api",
    "daimo:datasets": ["benchmark-synthetic"],
    "daimo:language": ["en"],
    "daimo:base_model": "logistic-linear-demo",
    "daimo:model_version": "1.0.0",
    "daimo:inference_path": "/infer",
    "daimo:input_schema_draft": "https://json-schema.org/draft/2020-12/schema",
    "daimo:input_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:pionera:schema:text-classification:v1",
      "title": "Text Classification Input",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Input text to classify."
        }
      },
      "required": ["text"],
      "additionalProperties": false
    },
    "daimo:input_features": [
      {
        "path": "text",
        "name": "text",
        "type": "string",
        "required": true,
        "description": "Input text to classify.",
        "example": "The UI is clean and support is helpful"
      }
    ],
    "daimo:input_example": {
      "text": "The UI is clean and support is helpful"
    }
  },
  "dataAddress": {
    "type": "HttpData",
    "baseUrl": "http://localhost:9203",
    "proxyPath": "true"
  }
}
