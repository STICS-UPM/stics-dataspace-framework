    "daimo:framework": ["scikit-learn"],
    "daimo:software": ["Python 3.11", "NumPy 1.26"],
    "daimo:format": "joblib",
    "daimo:datasets": ["iris"],
    "daimo:language": ["en"],
    "daimo:base_model": "pionera/base-model",
    "daimo:metrics": {
      "accuracy": 0.93,
      "f1_macro": 0.91
    }
  },
  "dataAddress": {
    "type": "HttpData",
    "baseUrl": "https://jsonplaceholder.typicode.com/users",
    "proxyPath": "true"
