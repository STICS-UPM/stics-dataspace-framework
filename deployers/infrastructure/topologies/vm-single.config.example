VM_EXTERNAL_IP=
VM_COMMON_IP=
VM_DATASPACE_IP=
VM_CONNECTORS_IP=
VM_COMPONENTS_IP=
INGRESS_EXTERNAL_IP=
DOMAIN_BASE=
DS_DOMAIN_BASE=
KC_URL=
KC_INTERNAL_URL=
KEYCLOAK_HOSTNAME=
KEYCLOAK_ADMIN_HOSTNAME=
MINIO_HOSTNAME=
MINIO_CONSOLE_HOSTNAME=
TOPOLOGY=vm-single
# Internal Kubernetes service used by deployed workloads. Leave blank to infer it.
DATABASE_HOSTNAME=
# Internal Vault service used by deployed workloads. Leave blank to infer it.
VAULT_URL=
CLUSTER_TYPE=k3s
K3S_KUBECONFIG=~/.kube/vm-single-k3s.yaml
K3S_INSTALL_EXEC=--disable=traefik
K3S_SERVICE_NAME=k3s
K3S_INGRESS_CONTROLLER=ingress-nginx
K3S_INGRESS_SERVICE_TYPE=LoadBalancer
K3S_REPAIR_ON_LEVEL1=prompt
K3S_WRITE_KUBECONFIG_MODE=0644
VM_SINGLE_LOCAL_KUBECONFIG=~/.kube/vm-single-k3s.yaml
VM_SINGLE_REMOTE_KUBECONFIG=/etc/rancher/k3s/k3s.yaml
VM_SINGLE_K3S_TUNNEL_MODE=auto
VM_SINGLE_K3S_API_LOCAL_PORT=46443
VM_SINGLE_K3S_API_REMOTE_PORT=6443
VM_SINGLE_REMOTE_IMAGE_IMPORT=auto
VM_SINGLE_REMOTE_IMAGE_IMPORT_COMMAND=sudo -n k3s ctr -n k8s.io images import
VM_SINGLE_REMOTE_IMAGE_IMPORT_DIR=/tmp
VM_SINGLE_REMOTE_IMAGE_IMPORT_INTERACTIVE=auto
VM_SINGLE_REMOTE_IMAGE_IMPORT_TTY=false
VM_SINGLE_REMOTE_IMAGE_PRUNE=false
VM_SINGLE_REMOTE_IMAGE_PRUNE_KEEP=2
VM_SINGLE_K3S_LEVEL3_IMAGE_PREPULL=false
VM_SINGLE_PUBLIC_URL=
VM_SINGLE_HTTP_URL=
VM_SINGLE_CONNECTOR_PUBLIC_PATH_PREFIX=/c
# EDC uses a separate default path space so it can coexist with INESData on
# the same vm-single host, e.g. /edc/c/org2.
EDC_VM_SINGLE_CONNECTOR_PUBLIC_PATH_PREFIX=/edc/c
COMPONENTS_PUBLIC_BASE_URL=
COMPONENTS_PUBLIC_PATH_REWRITE=true
VM_DISTRIBUTED_COMPONENT_PUBLIC_PATH_INGRESS_OWNER=level5
# vm-single uses k3s and serves connector UIs through path prefixes such as
# /c/org2. Level 4 builds and imports local connector images by default so the
# runtime image matches the framework sources and supports those public paths.
LEVEL4_LOCAL_IMAGES_MODE=auto
LEVEL5_AUTO_BUILD_LOCAL_IMAGES=true
LEVEL6_AUTO_BUILD_LOCAL_IMAGES=true
LEVEL5_ASSUME_LOCAL_IMAGES_AVAILABLE=false
LEVEL6_ASSUME_LOCAL_IMAGES_AVAILABLE=false
INESDATA_CONNECTOR_IMAGE_NAME=
INESDATA_CONNECTOR_IMAGE_TAG=
INESDATA_CONNECTOR_INTERFACE_IMAGE_NAME=
INESDATA_CONNECTOR_INTERFACE_IMAGE_TAG=
EDC_CONNECTOR_IMAGE_NAME=
EDC_CONNECTOR_IMAGE_TAG=
EDC_SQL_SCHEMA_AUTOCREATE=true
# Optional prebuilt Level 5 component images for this topology. Configure full
# image references with explicit tags when component charts otherwise use
# repository:local images.
COMPONENTS_IMAGE_PULL_POLICY=
ONTOLOGY_HUB_IMAGE_REF=
AI_MODEL_HUB_IMAGE_REF=
SEMANTIC_VIRTUALIZATION_IMAGE_REF=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_IMAGE_REF=
# AI_MODEL_HUB_MODEL_SERVER_ENABLED controls whether Level 5 deploys/manages the
# model-server. Set it to true only when this topology owns that service.
AI_MODEL_HUB_MODEL_SERVER_ENABLED=false
# AI_MODEL_HUB_MODEL_SERVER_MODE accepts blank, mock, use-cases, combined or external.
# blank/mock uses the controlled deterministic model-server baseline.
# use-cases/combined uses adapters/inesdata/sources/AIModelHub-Use-Cases and clones
# the official ProyectoPIONERA/AIModelHub-Use-Cases repository when explicitly enabled.
# For external, configure AI_MODEL_HUB_MODEL_SERVER_CONNECTOR_BASE_URL explicitly.
AI_MODEL_HUB_MODEL_SERVER_IMAGE=
AI_MODEL_HUB_MODEL_SERVER_MODE=
AI_MODEL_HUB_MODEL_SERVER_SOURCE_DIR=
AI_MODEL_HUB_MODEL_SERVER_SOURCE_REPOSITORY=
AI_MODEL_HUB_MODEL_SERVER_SOURCE_REF=
AI_MODEL_HUB_MODEL_SERVER_MANIFEST_PATH=
AI_MODEL_HUB_MODEL_SERVER_READINESS_PATH=
AI_MODEL_HUB_MODEL_SERVER_CONTAINER_PORT=
AI_MODEL_HUB_MODEL_SERVER_DOCKER_BASE_IMAGE=
AI_MODEL_HUB_MODEL_SERVER_UVICORN_APP=
AI_MODEL_HUB_MODEL_SERVER_IMAGE_PULL_POLICY=
AI_MODEL_HUB_MODEL_SERVER_COPY_EXCLUDES=
AI_MODEL_HUB_MODEL_SERVER_CONNECTOR_BASE_URL=
AI_MODEL_HUB_MODEL_SERVER_PUBLIC_URL=
AI_MODEL_HUB_MODEL_SERVER_VALIDATION_URL=
AI_MODEL_HUB_MODEL_SERVER_VALIDATION_DISCOVERY_PATH=
AI_MODEL_HUB_MODEL_SERVER_VALIDATION_DATASETS_PATH=
AI_MODEL_HUB_MODEL_SERVER_VALIDATION_ENDPOINTS=
AI_MODEL_HUB_MODEL_SERVER_VALIDATION_PAYLOAD=
AI_MODEL_HUB_REAL_MODELS_ARTIFACT_DIR=
AI_MODEL_HUB_REAL_MODELS_TRAIN_COMMAND=
ONTOLOGY_HUB_PUBLIC_URL=
ONTOLOGY_HUB_VERSIONS_PERSISTENCE_ENABLED=true
ONTOLOGY_HUB_VERSIONS_PERSISTENCE_SIZE=1Gi
# Server-side URL used by Ontology Hub when it analyzes uploaded versions.
# Leave blank to infer http://<dataspace>-ontology-hub.<components-namespace>:3333.
ONTOLOGY_HUB_SELF_HOST_URL=
ONTOLOGY_HUB_SELF_HOST_SERVICE_NAME=
ONTOLOGY_HUB_SELF_HOST_NAMESPACE=components
ONTOLOGY_HUB_SELF_HOST_SERVICE_PORT=3333
AI_MODEL_HUB_PUBLIC_URL=
SEMANTIC_VIRTUALIZATION_PUBLIC_URL=
# Optional Streamlit mapping editor exposure. Use a dedicated public URL when
# the reverse proxy must support WebSocket upgrade without path rewriting.
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_URL=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_PUBLIC_URL=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_EXPOSURE_MODE=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_HOST_PORT=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_PUBLIC_HOST=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_NAMESPACE=components
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_SERVICE_NAME=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_SERVICE_PORT=8501
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_SERVICE_TYPE=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_NODE_PORT=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_TUNNEL_MODE=auto
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_TUNNEL_LOCAL_PORT=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_TUNNEL_REMOTE_HOST=127.0.0.1
# FRAMEWORK_EXECUTION_MODE accepts auto, orchestrator or target-vm/common-services.
# orchestrator is the recommended workstation/WSL mode; target-vm/common-services
# means the framework is executed directly inside the target VM.
FRAMEWORK_EXECUTION_MODE=auto
VM_SINGLE_LEVEL_EXECUTION_MODE=auto
VM_SINGLE_REMOTE_PYTHON=python3
VM_SINGLE_REMOTE_WORKDIR=
VM_SINGLE_WORKSPACE_SYNC=disabled
VM_SINGLE_WORKSPACE_SYNC_DELETE=false
VM_SINGLE_WORKSPACE_SYNC_EXCLUDES=
VM_REMOTE_WORKDIR=
VM_SSH_USER=
SSH_ACCESS_MODE=
SSH_BASTION_HOST=
SSH_BASTION_PORT=2222
SSH_BASTION_USER=
SSH_BASTION_IDENTITY_FILE=
SSH_IDENTITY_FILE=
SSH_CONNECT_TIMEOUT_SECONDS=5
VM_SINGLE_SSH_HOST=
VM_SINGLE_SSH_PORT=22
VM_SINGLE_SSH_USER=
VM_SINGLE_SSH_IDENTITY_FILE=
VM_SINGLE_SSH_BOOTSTRAP_MODE=manual
VM_SINGLE_SSH_KEY_COMMENT=validation-environment-vm-single
VM_SINGLE_SSH_MANAGED_MARKER=validation-environment-vm-single
VM_SINGLE_SSH_KNOWN_HOSTS_STRATEGY=accept-new
