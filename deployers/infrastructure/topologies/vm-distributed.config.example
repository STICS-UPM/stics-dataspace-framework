VM_EXTERNAL_IP=
VM_COMMON_IP=
VM_DATASPACE_IP=
VM_PROVIDER_IP=
VM_CONSUMER_IP=
VM_PROVIDER_K8S_NODE=
VM_CONSUMER_K8S_NODE=
VM_CONNECTORS_IP=
VM_COMPONENTS_IP=
VM_OBSERVABILITY_IP=
VM_SSH_USER=
INGRESS_EXTERNAL_IP=
CLUSTER_TYPE=k3s
K3S_KUBECONFIG=/etc/rancher/k3s/k3s.yaml
K3S_KUBECONFIG_COMMON=/etc/rancher/k3s/k3s.yaml
K3S_KUBECONFIG_PROVIDER=
K3S_KUBECONFIG_CONSUMER=
K3S_KUBECONFIG_COMPONENTS=
K3S_INSTALL_EXEC=--disable=traefik
K3S_SERVICE_NAME=k3s
K3S_INGRESS_CONTROLLER=ingress-nginx
K3S_INGRESS_SERVICE_TYPE=LoadBalancer
K3S_INGRESS_HTTP_NODEPORT=
K3S_REPAIR_ON_LEVEL1=prompt
K3S_WRITE_KUBECONFIG_MODE=0644
KEYCLOAK_BOOTSTRAP_PORT_FORWARD=

# Browser-facing URLs. Leave blank to infer safe defaults from DOMAIN_BASE and
# DS_DOMAIN_BASE, for example:
# VM_COMMON_PUBLIC_URL=https://org1.<DOMAIN_BASE>
# VM_PROVIDER_PUBLIC_URL=https://org2.<DS_DOMAIN_BASE>
# VM_CONSUMER_PUBLIC_URL=https://org3.<DS_DOMAIN_BASE>
# KEYCLOAK_FRONTEND_URL=https://org1.<DOMAIN_BASE>/auth
# MINIO_API_PUBLIC_URL=https://org1.<DOMAIN_BASE>
# MINIO_CONSOLE_PUBLIC_URL=https://org1.<DOMAIN_BASE>/s3-console
# COMPONENTS_PUBLIC_BASE_URL=https://org1.<DOMAIN_BASE>
# VM_PUBLIC_PROXY_IP=<public reverse proxy IP used by external operators>
# Set explicit full URLs when an organization uses different domains,
# subdomains or gateway paths.
KEYCLOAK_FRONTEND_URL=
KEYCLOAK_PUBLIC_URL=
VM_PUBLIC_PROXY_IP=
MINIO_API_PUBLIC_URL=
MINIO_CONSOLE_PUBLIC_URL=
MINIO_PUBLIC_URL=
MINIO_CONSOLE_PUBLIC_ROOT_ALIASES_ENABLED=true
MINIO_CONSOLE_PUBLIC_ROOT_ALIASES=/api,/static,/ws,/browser,/login,/oauth,/screens,/favicon.ico,/manifest.json
COMPONENTS_PUBLIC_BASE_URL=
COMPONENTS_PUBLIC_PATH_REWRITE=true
# Level 5 owns component ingresses by default to keep routes tied to Helm releases.
# Use infrastructure only for legacy deployments that still require pre-created routes.
VM_DISTRIBUTED_COMPONENT_PUBLIC_PATH_INGRESS_OWNER=level5
# Connector-side model execution URL. Leave blank to infer
# http://org1.<DOMAIN_BASE>/model-server for vm-distributed deployments.
# Set an explicit HTTPS URL only when connector runtimes trust that certificate chain.
AI_MODEL_HUB_MODEL_SERVER_CONNECTOR_BASE_URL=
# Connector-side Observer journal URL. Leave blank to infer
# http://org1.<DOMAIN_BASE>/public-portal-backend for vm-distributed deployments.
# Browser-facing Observer URLs can remain HTTPS; this URL is used by connector runtimes.
AI_MODEL_OBSERVER_JOURNAL_BASE_URL=
# Optional component-specific full URL overrides.
ONTOLOGY_HUB_PUBLIC_URL=
# Server-side URL used by Ontology Hub when it analyzes uploaded versions.
# Leave blank to infer http://org1.<DOMAIN_BASE>/ontology-hub in vm-distributed.
ONTOLOGY_HUB_SELF_HOST_URL=
# Ontology Hub uses absolute application paths for pages and static assets.
# Keep the default unless another public reverse proxy already rewrites them.
# ONTOLOGY_HUB_PUBLIC_ROOT_ALIASES=/dataset,/edition,/css,/js,/img
AI_MODEL_HUB_PUBLIC_URL=
SEMANTIC_VIRTUALIZATION_PUBLIC_URL=
SEMANTIC_VIRTUALIZATION_MAPPING_EDITOR_URL=
TOPOLOGY_ROUTING_MODE=host
VM_PROVIDER_CONNECTORS=
VM_CONSUMER_CONNECTORS=
VM_PROVIDER_INGRESS_HTTP_PORT=80
VM_CONSUMER_INGRESS_HTTP_PORT=
VM_PROVIDER_INGRESS_NODEPORT=
VM_CONSUMER_INGRESS_NODEPORT=
DATABASE_HOSTNAME=
VAULT_URL=
VT_URL=
PIONERA_LEVEL6_MINIO_ENDPOINT=

# Optional SSH access metadata for remote preparation/preflight tools.
# Leave empty when kubectl/helm are executed from an already configured host.
# SSH_ACCESS_MODE accepts bastion or direct.
SSH_ACCESS_MODE=
SSH_BASTION_HOST=
SSH_BASTION_PORT=2222
SSH_BASTION_USER=
SSH_BASTION_IDENTITY_FILE=
SSH_IDENTITY_FILE=
SSH_CONNECT_TIMEOUT_SECONDS=5

# Optional orchestration/preflight metadata. Keep real workspace paths in local .config files.
# VM_DISTRIBUTED_EXECUTION_HOST accepts auto, external or common-services.
# auto keeps WSL/operator workflows external and switches to common-services when
# the framework is executed directly inside the common-services VM.
VM_DISTRIBUTED_EXECUTION_HOST=auto
VM_DISTRIBUTED_COMMON_VM_DIRECT_SSH=true
VM_DISTRIBUTED_INFER_LOCAL_WORKDIR=true
VM_DISTRIBUTED_KUBECONFIG_AUTO_LOCALIZE=true
VM_DISTRIBUTED_KUBECONFIG_DIR=~/.kube
VM_DISTRIBUTED_KUBECONFIG_SYNC=auto
VM_DISTRIBUTED_REMOTE_KUBECONFIG=/etc/rancher/k3s/k3s.yaml
VM_DISTRIBUTED_HTTP_PREFLIGHT_TLS_VERIFY=auto
VM_DISTRIBUTED_SSH_BOOTSTRAP_MODE=manual
VM_DISTRIBUTED_SSH_KEY_COMMENT=validation-environment-vm-distributed
VM_DISTRIBUTED_SSH_MANAGED_MARKER=validation-environment-vm-distributed
VM_DISTRIBUTED_SSH_KNOWN_HOSTS_STRATEGY=accept-new
VM_DISTRIBUTED_DEPLOYMENT_MODE=orchestrator
VM_DISTRIBUTED_PREFLIGHT_DRY_RUN=true
VM_DISTRIBUTED_K3S_TUNNEL_MODE=auto
VM_DISTRIBUTED_K3S_API_REMOTE_PORT=6443
VM_DISTRIBUTED_K3S_TUNNEL_RECREATE=auto
VM_COMMON_K3S_API_LOCAL_PORT=6443
VM_PROVIDER_K3S_API_LOCAL_PORT=26443
VM_CONSUMER_K3S_API_LOCAL_PORT=36443
VM_COMPONENTS_K3S_API_LOCAL_PORT=6443
VM_DISTRIBUTED_REMOTE_IMAGE_IMPORT=false
VM_DISTRIBUTED_REMOTE_IMAGE_IMPORT_COMMAND=sudo -n k3s ctr -n k8s.io images import
VM_DISTRIBUTED_REMOTE_IMAGE_IMPORT_DIR=/tmp
VM_DISTRIBUTED_REMOTE_IMAGE_IMPORT_INTERACTIVE=auto
VM_DISTRIBUTED_REMOTE_IMAGE_IMPORT_TTY=false
VM_DISTRIBUTED_REMOTE_IMAGE_PRUNE=false
VM_DISTRIBUTED_REMOTE_IMAGE_PRUNE_KEEP=2
VM_REMOTE_WORKDIR=
VM_COMMON_REMOTE_WORKDIR=
VM_PROVIDER_REMOTE_WORKDIR=
VM_CONSUMER_REMOTE_WORKDIR=
VM_COMMON_PUBLIC_URL=
VM_PROVIDER_PUBLIC_URL=
VM_CONSUMER_PUBLIC_URL=
CONNECTOR_PROTOCOL_ADDRESS_MODE=internal
VM_COMMON_HTTP_URL=
VM_PROVIDER_HTTP_URL=
VM_CONSUMER_HTTP_URL=

VM_COMMON_SSH_HOST=
VM_COMMON_SSH_PORT=22
VM_COMMON_SSH_USER=
VM_COMMON_SSH_IDENTITY_FILE=
VM_COMPONENTS_SSH_HOST=
VM_COMPONENTS_SSH_PORT=22
VM_COMPONENTS_SSH_USER=
VM_COMPONENTS_SSH_IDENTITY_FILE=
VM_PROVIDER_SSH_HOST=
VM_PROVIDER_SSH_PORT=22
VM_PROVIDER_SSH_USER=
VM_PROVIDER_SSH_IDENTITY_FILE=
VM_CONSUMER_SSH_HOST=
VM_CONSUMER_SSH_PORT=22
VM_CONSUMER_SSH_USER=
VM_CONSUMER_SSH_IDENTITY_FILE=
