# Base URL del portal del conector (sin slash final)
PORTAL_BASE_URL=https://conn-citycouncil-demo.dev.ed.inesdata.upm

# Credenciales del login Keycloak del portal
PORTAL_USER=user-conn-citycouncil-demo
PORTAL_PASSWORD=change-me

# Alternativa parametrizable al modo anterior:
# UI_PORTAL_CONNECTOR=conn-citycouncil-demo
# UI_PORTAL_ROLE=provider
#
# Para flujos de dataspace:
# UI_PROVIDER_CONNECTOR=conn-citycouncil-demo
# UI_CONSUMER_CONNECTOR=conn-company-demo
# UI_DATASPACE=demo
# UI_ENVIRONMENT=DEV
# UI_DS_DOMAIN=dev.ds.dataspaceunit.upm

# Tamano del archivo de prueba en MB.
# Usar > 50 para forzar upload por chunks de 50MB (comportamiento actual del frontend)
PORTAL_TEST_FILE_MB=60

# Prefijo para la carpeta/objeto usada por la subida de pruebas
PORTAL_TEST_OBJECT_PREFIX=playwright-e2e

# Si ya llegas autenticado por otro mecanismo, puedes omitir login automatico
PORTAL_SKIP_LOGIN=false

# Overrides opcionales para redirigir artefactos de Playwright
# PLAYWRIGHT_OUTPUT_DIR=test-results
# PLAYWRIGHT_HTML_REPORT_DIR=playwright-report
# PLAYWRIGHT_BLOB_REPORT_DIR=blob-report
# PLAYWRIGHT_JSON_REPORT_FILE=test-results/results.json

# Suite ops opcional para MinIO Console
# Si se omiten los buckets, se derivan como <dataspace>-<connectorName>
# UI_MINIO_CONSOLE_URL=http://console.minio-s3.dev.ed.dataspaceunit.upm
# UI_MINIO_PROVIDER_BUCKET=demo-conn-citycouncil-demo
# UI_MINIO_CONSUMER_BUCKET=demo-conn-company-demo
# UI_MINIO_PROVIDER_EXPECT_OBJECT=
# UI_MINIO_CONSUMER_EXPECT_OBJECT=
