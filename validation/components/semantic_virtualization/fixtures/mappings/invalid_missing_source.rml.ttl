@prefix mob: <https://w3id.org/pionera/validation/mobility#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .

<#InvalidTriplesMap>
    a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "sources/csv/missing-stops.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/pionera/validation/resource/invalid/{stop_id}" ;
        rr:class mob:Stop
    ] ;
    rr:predicateObjectMap [
        rr:predicate mob:undefinedPredicate ;
        rr:objectMap [ rml:reference "stop_name" ]
    ] .
