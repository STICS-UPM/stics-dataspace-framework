@prefix ex: <https://w3id.org/pionera/validation/resource/> .
@prefix mob: <https://w3id.org/pionera/validation/mobility#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .

<#StopTriplesMap>
    a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "sources/csv/stops.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/pionera/validation/resource/stop/{stop_id}" ;
        rr:class mob:Stop
    ] ;
    rr:predicateObjectMap [
        rr:predicate mob:hasStopName ;
        rr:objectMap [ rml:reference "stop_name" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mob:hasLatitude ;
        rr:objectMap [ rml:reference "stop_lat" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mob:hasLongitude ;
        rr:objectMap [ rml:reference "stop_lon" ]
    ] .
