{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GTFS-Madrid-Bench-mini sample",
  "description": "Schema reference for the synthetic GTFS-like mobility fixture used in AI Model Hub validation.",
  "$defs": {
    "stop": {
      "type": "object",
      "required": [
        "stop_id",
        "stop_name",
        "stop_lat",
        "stop_lon",
        "zone_id"
      ],
      "properties": {
        "stop_id": {
          "type": "string"
        },
        "stop_name": {
          "type": "string"
        },
        "stop_lat": {
          "type": "number"
        },
        "stop_lon": {
          "type": "number"
        },
        "zone_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "route": {
      "type": "object",
      "required": [
        "route_id",
        "agency_id",
        "route_short_name",
        "route_long_name",
        "route_type"
      ],
      "properties": {
        "route_id": {
          "type": "string"
        },
        "agency_id": {
          "type": "string"
        },
        "route_short_name": {
          "type": "string"
        },
        "route_long_name": {
          "type": "string"
        },
        "route_type": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "trip": {
      "type": "object",
      "required": [
        "route_id",
        "service_id",
        "trip_id",
        "direction_id",
        "shape_id"
      ],
      "properties": {
        "route_id": {
          "type": "string"
        },
        "service_id": {
          "type": "string"
        },
        "trip_id": {
          "type": "string"
        },
        "direction_id": {
          "type": "integer",
          "enum": [
            0,
            1
          ]
        },
        "shape_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "stopTime": {
      "type": "object",
      "required": [
        "trip_id",
        "arrival_time",
        "departure_time",
        "stop_id",
        "stop_sequence"
      ],
      "properties": {
        "trip_id": {
          "type": "string"
        },
        "arrival_time": {
          "type": "string",
          "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$"
        },
        "departure_time": {
          "type": "string",
          "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$"
        },
        "stop_id": {
          "type": "string"
        },
        "stop_sequence": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "transferBenchmarkCase": {
      "type": "object",
      "required": [
        "case_id",
        "origin_stop_id",
        "destination_stop_id",
        "query_time",
        "expected_route_id",
        "expected_trip_id",
        "expected_duration_minutes"
      ],
      "properties": {
        "case_id": {
          "type": "string"
        },
        "origin_stop_id": {
          "type": "string"
        },
        "destination_stop_id": {
          "type": "string"
        },
        "query_time": {
          "type": "string",
          "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$"
        },
        "expected_route_id": {
          "type": "string"
        },
        "expected_trip_id": {
          "type": "string"
        },
        "expected_duration_minutes": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": [
    "stops",
    "routes",
    "trips",
    "stop_times",
    "transfer_benchmark_cases"
  ],
  "properties": {
    "stops": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stop"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/route"
      }
    },
    "trips": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trip"
      }
    },
    "stop_times": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stopTime"
      }
    },
    "transfer_benchmark_cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transferBenchmarkCase"
      }
    }
  },
  "additionalProperties": false
}
