        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets/request",
          "host": [
            "{{provider}}",
            "{{dsDomain}}"
          ],
          "path": [
            "management",
            "v3",
            "assets",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{crud_asset_id}}\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "description": "Versión Postman autocontenida de `List CRUD Assets`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let body;",
              "try { body = pm.response.json(); } catch (e) { pm.test(\"Response body is valid JSON\", function () { pm.expect.fail(\"Response body is not valid JSON\"); }); return; }",
              "pm.test(\"HTTP status is 200\", function () { pm.response.to.have.status(200); });",
              "const assetId = pm.collectionVariables.get(\"crud_asset_id\") || pm.environment.get(\"crud_asset_id\");",
              "pm.test(\"CRUD asset id is available\", function () { pm.expect(assetId).to.be.a(\"string\").and.not.empty; });",
              "pm.test(\"CRUD asset appears in asset lookup result\", function () { pm.expect(Array.isArray(body)).to.equal(true); pm.expect(body.some((asset) => asset && asset[\"@id\"] === assetId)).to.equal(true); });"
            ]
          }
        }
      ]
    },
