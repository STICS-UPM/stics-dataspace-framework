  "item": [
    {
      "name": "Provider Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": [
            "{{keycloakUrl}}"
          ],
          "path": [
            "realms",
            "{{dataspace}}",
            "protocol",
            "openid-connect",
            "token"
          ]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "password",
              "type": "text"
            },
            {
              "key": "client_id",
              "value": "{{keycloakClientId}}",
              "type": "text"
            },
            {
              "key": "username",
              "value": "{{provider_user}}",
              "type": "text"
            },
            {
              "key": "password",
              "value": "{{provider_password}}",
              "type": "text"
            },
            {
              "key": "scope",
              "value": "openid profile email",
              "type": "text"
            }
          ]
        },
        "description": "Versión Postman autocontenida de `Provider Login`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function setVar(key, value) {",
              "  pm.environment.set(key, value);",
              "  pm.collectionVariables.set(key, value);",
              "}",
              "",
              "let body;",
              "try {",
              "  body = pm.response.json();",
              "} catch (e) {",
              "  pm.test(\"Response body is valid JSON\", function () {",
              "    pm.expect.fail(\"Response body is not valid JSON\");",
              "  });",
              "  return;",
              "}",
              "",
              "pm.test(\"HTTP status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Provider login returns access_token\", function () {",
              "  pm.expect(body.access_token).to.be.a(\"string\").and.not.empty;",
              "});",
              "const suffix = String(Date.now());",
              "setVar(\"provider_jwt\", body.access_token);",
              "setVar(\"crud_suffix\", suffix);",
              "setVar(\"crud_asset_id\", `asset-crud-${suffix}`);",
              "setVar(\"crud_policy_id\", `policy-crud-${suffix}`);",
              "setVar(\"crud_contract_definition_id\", `contract-crud-${suffix}`);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create CRUD Asset",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets",
          "host": [
            "{{provider}}",
            "{{dsDomain}}"
          ],
          "path": [
            "management",
            "v3",
            "assets"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\n    \"dct\": \"http://purl.org/dc/terms/\",\n    \"dcat\": \"http://www.w3.org/ns/dcat#\"\n  },\n  \"@id\": \"{{crud_asset_id}}\",\n  \"@type\": \"Asset\",\n  \"properties\": {\n    \"name\": \"CRUD Test Asset {{crud_suffix}}\",\n    \"version\": \"1.0.0\",\n    \"shortDescription\": \"CRUD validation asset\",\n    \"assetType\": \"dataset\",\n    \"dct:description\": \"CRUD validation asset\",\n    \"dcat:keyword\": [\"validation\", \"crud\"]\n  },\n  \"dataAddress\": {\n    \"type\": \"HttpData\",\n    \"baseUrl\": \"https://jsonplaceholder.typicode.com/todos\",\n    \"name\": \"todos\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "description": "Versión Postman autocontenida de `Create CRUD Asset`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function setVar(key, value) { pm.environment.set(key, value); pm.collectionVariables.set(key, value); }",
              "let body;",
              "try { body = pm.response.json(); } catch (e) { pm.test(\"Response body is valid JSON\", function () { pm.expect.fail(\"Response body is not valid JSON\"); }); return; }",
              "pm.test(\"HTTP status indicates resource creation\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
              "pm.test(\"CRUD asset creation returns @id\", function () { pm.expect(body[\"@id\"] || pm.environment.get(\"crud_asset_id\")).to.exist; });",
              "if (body[\"@id\"]) { setVar(\"crud_asset_id\", body[\"@id\"]); }"
            ]
          }
        }
      ]
    },
    {
      "name": "List CRUD Assets",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
