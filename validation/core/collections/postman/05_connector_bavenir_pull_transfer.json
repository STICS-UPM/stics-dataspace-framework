{
  "info": {
    "name": "05 connector-bavenir PULL Transfer",
    "_postman_id": "connector-bavenir-pull-05",
    "description": "Self-contained collection proving a real HttpData-PULL transfer with connector-bavenir (the connector onboarded in the bavenir hands-on session) as PROVIDER and connector-stics as CONSUMER: Keycloak auth, asset/policy/contract-definition creation on connector-bavenir, DSP catalog fetch, contract negotiation, transfer, and a real authenticated data pull through connector-bavenir's own public data-plane. Run with environment '00 Environment - connector-bavenir PULL Transfer' via 'Run collection' in order. Fill provider_password/consumer_password locally first (provider_password from connector-bavenir's credentials.json, consumer_password from connector-stics's).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Provider (connector-bavenir) Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": ["{{keycloakUrl}}"],
          "path": ["realms", "{{dataspace}}", "protocol", "openid-connect", "token"]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "client_id", "value": "{{keycloakClientId}}", "type": "text" },
            { "key": "username", "value": "{{provider_user}}", "type": "text" },
            { "key": "password", "value": "{{provider_password}}", "type": "text" },
            { "key": "scope", "value": "openid profile email", "type": "text" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('provider token obtained', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.access_token).to.be.a('string');",
              "  pm.environment.set('provider_jwt', json.access_token);",
              "});"
            ]
          }
        }
      ],
      "id": "cb01-provider-login"
    },
    {
      "name": "Consumer (connector-stics) Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": ["{{keycloakUrl}}"],
          "path": ["realms", "{{dataspace}}", "protocol", "openid-connect", "token"]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "client_id", "value": "{{keycloakClientId}}", "type": "text" },
            { "key": "username", "value": "{{consumer_user}}", "type": "text" },
            { "key": "password", "value": "{{consumer_password}}", "type": "text" },
            { "key": "scope", "value": "openid profile email", "type": "text" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('consumer token obtained', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.access_token).to.be.a('string');",
              "  pm.environment.set('consumer_jwt', json.access_token);",
              "});"
            ]
          }
        }
      ],
      "id": "cb02-consumer-login"
    },
    {
      "name": "connector-bavenir: Create Asset",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('e2e_asset_id', 'connbavenir-pull-asset-' + Date.now());",
              "pm.environment.set('e2e_policy_id', 'connbavenir-pull-policy-' + Date.now());",
              "pm.environment.set('e2e_cd_id', 'connbavenir-pull-cd-' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('asset created', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{providerMgmt}}/v3/assets",
          "host": ["{{providerMgmt}}"],
          "path": ["v3", "assets"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\n    \"dcterms\": \"http://purl.org/dc/terms/\",\n    \"dcat\": \"http://www.w3.org/ns/dcat#\"\n  },\n  \"@id\": \"{{e2e_asset_id}}\",\n  \"properties\": {\n    \"name\": \"connector-bavenir pull test asset\",\n    \"contenttype\": \"application/json\",\n    \"version\": \"1.0.0\",\n    \"shortDescription\": \"connector-bavenir onboarding session test asset\",\n    \"description\": \"connector-bavenir onboarding session test asset\",\n    \"assetType\": \"dataset\",\n    \"dcterms:description\": \"connector-bavenir onboarding session test asset\",\n    \"dcat:keyword\": [\"stics\", \"bavenir\", \"onboarding-test\"]\n  },\n  \"dataAddress\": {\n    \"type\": \"HttpData\",\n    \"name\": \"connector-bavenir pull test asset\",\n    \"baseUrl\": \"https://jsonplaceholder.typicode.com/todos/1\",\n    \"proxyPath\": \"true\"\n  }\n}"
        }
      },
      "id": "cb03-create-asset"
    },
    {
      "name": "connector-bavenir: Create Policy",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{providerMgmt}}/v3/policydefinitions",
          "host": ["{{providerMgmt}}"],
          "path": ["v3", "policydefinitions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\", \"odrl\": \"http://www.w3.org/ns/odrl/2/\"},\n  \"@id\": \"{{e2e_policy_id}}\",\n  \"policy\": {\n    \"@context\": \"http://www.w3.org/ns/odrl.jsonld\",\n    \"@type\": \"Set\",\n    \"permission\": [], \"prohibition\": [], \"obligation\": []\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('policy created', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "id": "cb04-create-policy"
    },
    {
      "name": "connector-bavenir: Create Contract Definition",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{providerMgmt}}/v3/contractdefinitions",
          "host": ["{{providerMgmt}}"],
          "path": ["v3", "contractdefinitions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"},\n  \"@id\": \"{{e2e_cd_id}}\",\n  \"accessPolicyId\": \"{{e2e_policy_id}}\",\n  \"contractPolicyId\": \"{{e2e_policy_id}}\",\n  \"assetsSelector\": [\n    {\"@type\": \"CriterionDto\", \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\", \"operator\": \"=\", \"operandRight\": \"{{e2e_asset_id}}\"}\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('contract definition created', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "id": "cb05-create-cd"
    },
    {
      "name": "connector-stics: Fetch Catalog from connector-bavenir",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{consumer_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/catalog/request",
          "host": ["{{consumerMgmt}}"],
          "path": ["v3", "catalog", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"},\n  \"counterPartyAddress\": \"{{providerDsp}}\",\n  \"protocol\": \"dataspace-protocol-http\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "let datasets = json['dcat:dataset'] || json['http://www.w3.org/ns/dcat#dataset'] || [];",
              "if (!Array.isArray(datasets)) { datasets = [datasets]; }",
              "const assetId = pm.environment.get('e2e_asset_id');",
              "const ds = datasets.find(d => d['@id'] === assetId);",
              "pm.test('asset found in connector-bavenir catalog', function () { pm.expect(ds).to.not.be.undefined; });",
              "if (ds) {",
              "  let offer = ds['odrl:hasPolicy'] || ds['hasPolicy'];",
              "  if (Array.isArray(offer)) { offer = offer[0]; }",
              "  pm.environment.set('e2e_offer_id', offer['@id']);",
              "  console.log('offer id:', offer['@id']);",
              "} else {",
              "  console.log('datasets seen:', JSON.stringify(datasets.map(d => d['@id'])));",
              "}"
            ]
          }
        }
      ],
      "id": "cb06-fetch-catalog"
    },
    {
      "name": "connector-stics: Negotiate Contract",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{consumer_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/contractnegotiations",
          "host": ["{{consumerMgmt}}"],
          "path": ["v3", "contractnegotiations"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"},\n  \"@type\": \"ContractRequest\",\n  \"counterPartyAddress\": \"{{providerDsp}}\",\n  \"protocol\": \"dataspace-protocol-http\",\n  \"policy\": {\n    \"@context\": \"http://www.w3.org/ns/odrl.jsonld\",\n    \"@id\": \"{{e2e_offer_id}}\",\n    \"@type\": \"Offer\",\n    \"assigner\": \"{{providerParticipantId}}\",\n    \"target\": \"{{e2e_asset_id}}\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('negotiation started', function () { pm.expect(json['@id']).to.be.a('string'); });",
              "pm.environment.set('e2e_negotiation_id', json['@id']);",
              "pm.environment.set('e2e_negotiation_retries', '0');"
            ]
          }
        }
      ],
      "id": "cb07-negotiate"
    },
    {
      "name": "connector-stics: Check Negotiation Status (self-looping until FINALIZED)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{consumer_jwt}}" }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/contractnegotiations/{{e2e_negotiation_id}}",
          "host": ["{{consumerMgmt}}"],
          "path": ["v3", "contractnegotiations", "{{e2e_negotiation_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "console.log('negotiation state:', json.state);",
              "if (json.state === 'FINALIZED') {",
              "  pm.environment.set('e2e_agreement_id', json.contractAgreementId);",
              "  pm.test('negotiation finalized', function () { pm.expect(json.contractAgreementId).to.be.a('string'); });",
              "} else if (json.state === 'TERMINATED' || json.state === 'TERMINATING') {",
              "  throw new Error('Negotiation terminated: ' + JSON.stringify(json));",
              "} else {",
              "  const retries = parseInt(pm.environment.get('e2e_negotiation_retries') || '0', 10);",
              "  if (retries < 40) {",
              "    pm.environment.set('e2e_negotiation_retries', String(retries + 1));",
              "    const waitUntil = Date.now() + 3000; while (Date.now() < waitUntil) { /* blocking delay so the retry budget isn't burned before the async negotiation converges */ }",
              "    pm.execution.setNextRequest(pm.info.requestName);",
              "  } else {",
              "    throw new Error('Negotiation did not reach FINALIZED in time, last state: ' + json.state);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "id": "cb08-check-negotiation"
    },
    {
      "name": "connector-stics: Start Transfer (HttpData-PULL)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{consumer_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/transferprocesses",
          "host": ["{{consumerMgmt}}"],
          "path": ["v3", "transferprocesses"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"},\n  \"@type\": \"TransferRequestDto\",\n  \"connectorId\": \"{{providerParticipantId}}\",\n  \"counterPartyAddress\": \"{{providerDsp}}\",\n  \"contractId\": \"{{e2e_agreement_id}}\",\n  \"protocol\": \"dataspace-protocol-http\",\n  \"transferType\": \"HttpData-PULL\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('transfer started', function () { pm.expect(json['@id']).to.be.a('string'); });",
              "pm.environment.set('e2e_transfer_id', json['@id']);",
              "pm.environment.set('e2e_transfer_retries', '0');"
            ]
          }
        }
      ],
      "id": "cb09-start-transfer"
    },
    {
      "name": "connector-stics: Check Transfer Status (self-looping until STARTED/COMPLETED)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{consumer_jwt}}" }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/transferprocesses/{{e2e_transfer_id}}",
          "host": ["{{consumerMgmt}}"],
          "path": ["v3", "transferprocesses", "{{e2e_transfer_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "console.log('transfer state:', json.state);",
              "if (json.state === 'STARTED' || json.state === 'COMPLETED') {",
              "  pm.test('transfer started/completed', function () { pm.expect(json.state).to.be.oneOf(['STARTED', 'COMPLETED']); });",
              "} else if (json.state === 'TERMINATED') {",
              "  throw new Error('Transfer terminated: ' + JSON.stringify(json));",
              "} else {",
              "  const retries = parseInt(pm.environment.get('e2e_transfer_retries') || '0', 10);",
              "  if (retries < 40) {",
              "    pm.environment.set('e2e_transfer_retries', String(retries + 1));",
              "    const waitUntil = Date.now() + 3000; while (Date.now() < waitUntil) { /* blocking delay so the retry budget isn't burned before the async transfer starts */ }",
              "    pm.execution.setNextRequest(pm.info.requestName);",
              "  } else {",
              "    throw new Error('Transfer did not start in time, last state: ' + json.state);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "id": "cb10-check-transfer"
    },
    {
      "name": "connector-stics: Get EDR (Endpoint Data Reference)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{consumer_jwt}}" }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/edrs/{{e2e_transfer_id}}/dataaddress",
          "host": ["{{consumerMgmt}}"],
          "path": ["v3", "edrs", "{{e2e_transfer_id}}", "dataaddress"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('EDR obtained', function () { pm.expect(json.endpoint).to.be.a('string'); });",
              "pm.environment.set('e2e_edr_endpoint', json.endpoint);",
              "pm.environment.set('e2e_edr_authorization', json.authorization);"
            ]
          }
        }
      ],
      "id": "cb11-get-edr"
    },
    {
      "name": "connector-stics: Pull Real Data via EDR (through connector-bavenir's data-plane)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{e2e_edr_authorization}}" }
        ],
        "url": {
          "raw": "{{e2e_edr_endpoint}}",
          "host": ["{{e2e_edr_endpoint}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('pulled real data with HTTP 200', function () { pm.response.to.have.status(200); });",
              "console.log('PULLED DATA (served by connector-bavenir):', pm.response.text());"
            ]
          }
        }
      ],
      "id": "cb12-pull-data"
    }
  ]
}
