{
  "info": {
    "name": "01 Environment Health",
    "_postman_id": "postman-environment-health-01",
    "description": "Versión Postman autocontenida de la colección 01 Environment Health, con tests embebidos y sin dependencia de test_script inyectado por Newman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Provider Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": [
            "{{keycloakUrl}}"
          ],
          "path": [
            "realms",
            "{{dataspace}}",
            "protocol",
            "openid-connect",
            "token"
          ]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "password",
              "type": "text"
            },
            {
              "key": "client_id",
              "value": "{{keycloakClientId}}",
              "type": "text"
            },
            {
              "key": "username",
              "value": "{{provider_user}}",
              "type": "text"
            },
            {
              "key": "password",
              "value": "{{provider_password}}",
              "type": "text"
            },
            {
              "key": "scope",
              "value": "openid profile email",
              "type": "text"
            }
          ]
        },
        "description": "Versión Postman autocontenida de `Provider Login`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function setVar(key, value) {",
              "  pm.environment.set(key, value);",
              "  pm.collectionVariables.set(key, value);",
              "}",
              "",
              "let body;",
              "try {",
              "  body = pm.response.json();",
              "} catch (e) {",
              "  pm.test(\"Response body is valid JSON\", function () {",
              "    pm.expect.fail(\"Response body is not valid JSON\");",
              "  });",
              "  return;",
              "}",
              "",
              "pm.test(\"HTTP status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Provider login returns access_token\", function () {",
              "  pm.expect(body.access_token).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "setVar(\"provider_jwt\", body.access_token);"
            ]
          }
        }
      ]
    },
