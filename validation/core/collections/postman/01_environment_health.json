    {
      "name": "Provider Management API Health",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets/request",
          "host": [
            "{{provider}}",
            "{{dsDomain}}"
          ],
          "path": [
            "management",
            "v3",
            "assets",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": []\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "description": "Versión Postman autocontenida de `Provider Management API Health`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let body;",
              "try {",
              "  body = pm.response.json();",
              "} catch (e) {",
              "  pm.test(\"Response body is valid JSON\", function () {",
              "    pm.expect.fail(\"Response body is not valid JSON\");",
              "  });",
              "  return;",
              "}",
              "",
              "pm.test(\"Provider Management API Health returns 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Provider Management API Health returns JSON content\", function () {",
              "  pm.expect(body).to.not.equal(null);",
              "});",
              "pm.test(\"Provider Management API Health does not contain EDC error\", function () {",
              "  pm.expect(body && body.error).to.equal(undefined);",
              "});"
            ]
          }
        }
      ]
    },
