    {
      "name": "Provider DSP Catalog Endpoint",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/protocol/catalog/request",
          "host": [
            "{{provider}}",
            "{{dsDomain}}"
          ],
          "path": [
            "protocol",
            "catalog",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"protocol\": \"dataspace-protocol-http\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "description": "Versión Postman autocontenida de `Provider DSP Catalog Endpoint`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const status = pm.response.code;",
              "pm.test(\"Provider DSP Catalog Endpoint returns a recognized environment response\", function () {",
              "  pm.expect([200, 400, 401]).to.include(status);",
              "});",
              "if (status === 200) {",
              "  let body;",
              "  try {",
              "    body = pm.response.json();",
              "  } catch (e) {",
              "    pm.test(\"Response body is valid JSON\", function () {",
              "      pm.expect.fail(\"Response body is not valid JSON\");",
              "    });",
              "    return;",
              "  }",
              "  pm.test(\"Provider DSP Catalog Endpoint responded functionally\", function () {",
              "    pm.expect(body).to.not.equal(null);",
              "  });",
              "} else if (status === 401) {",
              "  pm.test(\"Provider DSP Catalog Endpoint requires authentication (tolerated)\", function () {",
              "    pm.expect(status).to.equal(401);",
              "  });",
              "} else {",
              "  pm.test(\"Provider DSP Catalog Endpoint returned tolerated non-functional response\", function () {",
              "    pm.expect(status).to.equal(400);",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
