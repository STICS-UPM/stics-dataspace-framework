    {
      "name": "Consumer: Negotiate Contract (PUSH demo)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consumer_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/contractnegotiations",
          "host": [
            "{{consumerMgmt}}"
          ],
          "path": [
            "v3",
            "contractnegotiations"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"},\n  \"@type\": \"ContractRequest\",\n  \"counterPartyAddress\": \"{{providerDsp}}\",\n  \"protocol\": \"dataspace-protocol-http\",\n  \"policy\": {\n    \"@context\": \"http://www.w3.org/ns/odrl.jsonld\",\n    \"@id\": \"{{e2e_push_offer_id}}\",\n    \"@type\": \"Offer\",\n    \"assigner\": \"{{providerParticipantId}}\",\n    \"target\": \"{{e2e_push_asset_id}}\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('push negotiation started', function () { pm.expect(json['@id']).to.be.a('string'); });",
              "pm.environment.set('e2e_push_negotiation_id', json['@id']);",
              "pm.environment.set('e2e_push_negotiation_retries', '0');"
            ]
          }
        }
      ],
      "id": "c9170e09-cdfd-4621-8b20-91f53de55a65"
    },
    {
      "name": "Consumer: Check Negotiation Status (PUSH demo, self-looping until FINALIZED)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consumer_jwt}}"
          }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/contractnegotiations/{{e2e_push_negotiation_id}}",
          "host": [
            "{{consumerMgmt}}"
          ],
          "path": [
            "v3",
            "contractnegotiations",
            "{{e2e_push_negotiation_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "console.log('push negotiation state:', json.state);",
              "if (json.state === 'FINALIZED') {",
              "  pm.environment.set('e2e_push_agreement_id', json.contractAgreementId);",
              "  pm.test('push negotiation finalized', function () { pm.expect(json.contractAgreementId).to.be.a('string'); });",
              "} else if (json.state === 'TERMINATED' || json.state === 'TERMINATING') {",
              "  throw new Error('Push negotiation terminated: ' + JSON.stringify(json));",
              "} else {",
              "  const retries = parseInt(pm.environment.get('e2e_push_negotiation_retries') || '0', 10);",
              "  if (retries < 40) {",
              "    pm.environment.set('e2e_push_negotiation_retries', String(retries + 1));",
              "    const waitUntil = Date.now() + 3000; while (Date.now() < waitUntil) { /* blocking delay so the retry budget isn't burned before the async negotiation converges */ }",
              "    pm.execution.setNextRequest(pm.info.requestName);",
              "  } else {",
              "    throw new Error('Push negotiation did not reach FINALIZED in time, last state: ' + json.state);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "id": "9f30d14f-25b0-4a70-9a86-bfb6b116e084"
    },
