    {
      "name": "Consumer: Check Transfer Status (PUSH demo, self-looping until COMPLETED)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consumer_jwt}}"
          }
        ],
        "url": {
          "raw": "{{consumerMgmt}}/v3/transferprocesses/{{e2e_push_transfer_id}}",
          "host": [
            "{{consumerMgmt}}"
          ],
          "path": [
            "v3",
            "transferprocesses",
            "{{e2e_push_transfer_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "console.log('push transfer state:', json.state);",
              "if (json.state === 'COMPLETED') {",
              "  pm.test('push transfer completed', function () { pm.expect(json.state).to.equal('COMPLETED'); });",
              "  console.log('PUSH transfer completed. Verify the real POST arrived by checking ~/push_sink_received.log on the consumer VM (192.168.122.239) \u2014 it should show X-Real-IP of the provider VM (178.105.249.140).');",
              "} else if (json.state === 'TERMINATED') {",
              "  throw new Error('Push transfer terminated: ' + JSON.stringify(json));",
              "} else {",
              "  const retries = parseInt(pm.environment.get('e2e_push_transfer_retries') || '0', 10);",
              "  if (retries < 40) {",
              "    pm.environment.set('e2e_push_transfer_retries', String(retries + 1));",
              "    const waitUntil = Date.now() + 3000; while (Date.now() < waitUntil) { /* blocking delay so the retry budget isn't burned before the async push completes */ }",
              "    pm.execution.setNextRequest(pm.info.requestName);",
              "  } else {",
              "    throw new Error('Push transfer did not complete in time, last state: ' + json.state);",
              "  }",
              "}"
            ]
          }
        }
      ],
