{
  "info": {
    "name": "04 STICS EDC Interop (PULL + PUSH)",
    "_postman_id": "stics-edc-interop-04",
    "description": "Self-contained collection proving real interoperability between the STICS provider (connector-stics) and consumer (conlab-stics) EDC connectors: Keycloak auth, asset/policy/contract-definition creation, DSP catalog fetch, contract negotiation, and both HttpData-PULL and HttpData-PUSH transfers. Run with environment '00 Environment - STICS EDC Interop' via 'Run collection' in order. Fill provider_password/consumer_password locally first (see docs/47_stics_edc_interop_evidence.md).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Provider Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
