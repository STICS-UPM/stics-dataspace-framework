{
  "info": {
    "name": "02 Connector Management CRUD",
    "_postman_id": "connector-management-02",
    "description": "CRUD validation for provider connector management entities",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "eval(pm.environment.get('test_script'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Provider Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": ["{{keycloakUrl}}"],
          "path": ["realms", "{{dataspace}}", "protocol", "openid-connect", "token"]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "client_id", "value": "{{keycloakClientId}}", "type": "text" },
            { "key": "username", "value": "{{provider_user}}", "type": "text" },
            { "key": "password", "value": "{{provider_password}}", "type": "text" },
            { "key": "scope", "value": "openid profile email", "type": "text" }
          ]
        }
      }
    },
    {
      "name": "Create CRUD Asset",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "assets"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\n    \"dct\": \"http://purl.org/dc/terms/\",\n    \"dcat\": \"http://www.w3.org/ns/dcat#\"\n  },\n  \"@id\": \"{{crud_asset_id}}\",\n  \"@type\": \"Asset\",\n  \"properties\": {\n    \"name\": \"CRUD Test Asset {{crud_suffix}}\",\n    \"version\": \"1.0.0\",\n    \"shortDescription\": \"CRUD validation asset\",\n    \"assetType\": \"dataset\",\n    \"dct:description\": \"CRUD validation asset\",\n    \"dcat:keyword\": [\"validation\", \"crud\"]\n  },\n  \"dataAddress\": {\n    \"type\": \"HttpData\",\n    \"baseUrl\": \"https://jsonplaceholder.typicode.com/todos\",\n    \"name\": \"todos\"\n  }\n}"
        }
      }
    },
    {
      "name": "List CRUD Assets",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "assets", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{crud_asset_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Create CRUD Policy",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/policydefinitions",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "policydefinitions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\n    \"odrl\": \"http://www.w3.org/ns/odrl/2/\"\n  },\n  \"@id\": \"{{crud_policy_id}}\",\n  \"policy\": {\n    \"@context\": \"http://www.w3.org/ns/odrl.jsonld\",\n    \"@type\": \"Set\",\n    \"permission\": [],\n    \"prohibition\": [],\n    \"obligation\": []\n  }\n}"
        }
      }
    },
    {
      "name": "List CRUD Policies",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/policydefinitions/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "policydefinitions", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{crud_policy_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Create CRUD Contract Definition",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/contractdefinitions",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "contractdefinitions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"@id\": \"{{crud_contract_definition_id}}\",\n  \"accessPolicyId\": \"{{crud_policy_id}}\",\n  \"contractPolicyId\": \"{{crud_policy_id}}\",\n  \"assetsSelector\": [\n    {\n      \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{crud_asset_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "List CRUD Contract Definitions",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/contractdefinitions/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "contractdefinitions", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{crud_contract_definition_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Delete CRUD Contract Definition",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/contractdefinitions/{{crud_contract_definition_id}}",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "contractdefinitions", "{{crud_contract_definition_id}}"]
        }
      }
    },
    {
      "name": "Verify CRUD Contract Definition Deleted",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/contractdefinitions/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "contractdefinitions", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{crud_contract_definition_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Delete CRUD Policy",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/policydefinitions/{{crud_policy_id}}",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "policydefinitions", "{{crud_policy_id}}"]
        }
      }
    },
    {
      "name": "Verify CRUD Policy Deleted",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/policydefinitions/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "policydefinitions", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{crud_policy_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Delete CRUD Asset",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets/{{crud_asset_id}}",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "assets", "{{crud_asset_id}}"]
        }
      }
    },
    {
      "name": "Verify CRUD Asset Deleted",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "assets", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 50,\n  \"filterExpression\": []\n}"
        }
      }
    }
  ]
}
