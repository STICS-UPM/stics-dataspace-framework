{
  "info": {
    "name": "01 Environment Health",
    "_postman_id": "environment-health-01",
    "description": "Basic connectivity and API health checks for connectors",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "eval(pm.environment.get('test_script'));"
        ]
      }
    }
  ],

  "item": [

    {
      "name": "Provider Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": [
            "{{keycloakUrl}}"
          ],
          "path": [
            "realms",
            "{{dataspace}}",
            "protocol",
            "openid-connect",
            "token"
          ]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "client_id", "value": "{{keycloakClientId}}", "type": "text" },
            { "key": "username", "value": "{{provider_user}}", "type": "text" },
            { "key": "password", "value": "{{provider_password}}", "type": "text" },
            { "key": "scope", "value": "openid profile email", "type": "text" }
          ]
        }
      }
    },

    {
      "name": "Consumer Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": [
            "{{keycloakUrl}}"
          ],
          "path": [
            "realms",
            "{{dataspace}}",
            "protocol",
            "openid-connect",
            "token"
          ]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "client_id", "value": "{{keycloakClientId}}", "type": "text" },
            { "key": "username", "value": "{{consumer_user}}", "type": "text" },
            { "key": "password", "value": "{{consumer_password}}", "type": "text" },
            { "key": "scope", "value": "openid profile email", "type": "text" }
          ]
        }
      }
    },

    {
      "name": "Provider Management API Health",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets/request",
          "host": [
            "{{provider}}",
            "{{dsDomain}}"
          ],
          "path": [
            "management",
            "v3",
            "assets",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": []\n}"
        }
      }
    },

    {
      "name": "Consumer Management API Health",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consumer_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{consumer}}.{{dsDomain}}/management/v3/assets/request",
          "host": [
            "{{consumer}}",
            "{{dsDomain}}"
          ],
          "path": [
            "management",
            "v3",
            "assets",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": []\n}"
        }
      }
    },

    {
      "name": "Provider DSP Catalog Endpoint",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{provider_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/protocol/catalog/request",
          "host": [
            "{{provider}}",
            "{{dsDomain}}"
          ],
          "path": [
            "protocol",
            "catalog",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"protocol\": \"dataspace-protocol-http\"\n}"
        }
      }
    },

    {
      "name": "Consumer DSP Catalog Endpoint",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consumer_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{consumer}}.{{dsDomain}}/protocol/catalog/request",
          "host": [
            "{{consumer}}",
            "{{dsDomain}}"
          ],
          "path": [
            "protocol",
            "catalog",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"protocol\": \"dataspace-protocol-http\"\n}"
        }
      }
    }

  ]
}
