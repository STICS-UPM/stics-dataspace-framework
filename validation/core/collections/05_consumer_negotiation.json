{
  "info": {
    "name": "05 Consumer Contract Negotiation",
    "_postman_id": "consumer-negotiation-05",
    "description": "Consumer negotiates contract with provider",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "eval(pm.environment.get('test_script'));"
        ]
      }
    }
  ],

  "item": [

    {
      "name": "Consumer Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": [
            "{{keycloakUrl}}"
          ],
          "path": [
            "realms",
            "{{dataspace}}",
            "protocol",
            "openid-connect",
            "token"
          ]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "client_id", "value": "{{keycloakClientId}}", "type": "text" },
            { "key": "username", "value": "{{consumer_user}}", "type": "text" },
            { "key": "password", "value": "{{consumer_password}}", "type": "text" },
            { "key": "scope", "value": "openid profile email", "type": "text" }
          ]
        }
      }
    },

    {
      "name": "Start Contract Negotiation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consumer_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{consumer}}.{{dsDomain}}/management/v3/contractnegotiations",
          "host": [
            "{{consumer}}",
            "{{dsDomain}}"
          ],
          "path": [
            "management",
            "v3",
            "contractnegotiations"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"@type\": \"ContractRequest\",\n  \"counterPartyAddress\": \"{{providerProtocolAddress}}\",\n  \"protocol\": \"dataspace-protocol-http\",\n  \"policy\": {\n    \"@context\": \"http://www.w3.org/ns/odrl.jsonld\",\n    \"@type\": \"odrl:Offer\",\n    \"@id\": \"{{e2e_offer_policy_id}}\",\n    \"assigner\": \"{{providerParticipantId}}\",\n    \"target\": \"{{e2e_catalog_asset_id}}\",\n    \"permission\": [],\n    \"prohibition\": [],\n    \"obligation\": []\n  }\n}"
        }
      }
    },

    {
      "name": "Check Negotiation Status",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consumer_jwt}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{consumer}}.{{dsDomain}}/management/v3/contractnegotiations/request",
          "host": [
            "{{consumer}}",
            "{{dsDomain}}"
          ],
          "path": [
            "management",
            "v3",
            "contractnegotiations",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 100\n}"
        }
      }
    }

  ]
}
