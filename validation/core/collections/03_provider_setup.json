{
  "info": {
    "name": "03 Provider Setup",
    "_postman_id": "provider-setup-03",
    "description": "Prepare the provider connector entities required by the end-to-end dataspace scenario",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "eval(pm.environment.get('test_script'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Provider Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
        ],
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{dataspace}}/protocol/openid-connect/token",
          "host": ["{{keycloakUrl}}"],
          "path": ["realms", "{{dataspace}}", "protocol", "openid-connect", "token"]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "client_id", "value": "{{keycloakClientId}}", "type": "text" },
            { "key": "username", "value": "{{provider_user}}", "type": "text" },
            { "key": "password", "value": "{{provider_password}}", "type": "text" },
            { "key": "scope", "value": "openid profile email", "type": "text" }
          ]
        }
      }
    },
    {
      "name": "Create E2E Asset",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "assets"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\n    \"dct\": \"http://purl.org/dc/terms/\",\n    \"dcat\": \"http://www.w3.org/ns/dcat#\"\n  },\n  \"@id\": \"{{e2e_asset_id}}\",\n  \"@type\": \"Asset\",\n  \"properties\": {\n    \"name\": \"E2E Dataspace Asset {{e2e_suffix}}\",\n    \"version\": \"1.0.0\",\n    \"shortDescription\": \"Asset for end-to-end dataspace validation\",\n    \"assetType\": \"dataset\",\n    \"dct:description\": \"Asset for end-to-end dataspace validation\",\n    \"dcat:keyword\": [\"validation\", \"e2e\", \"dataspace\"],\n    \"sourceObjectName\": \"{{e2e_source_object_name}}\"\n  },\n  \"dataAddress\": {\n    \"type\": \"HttpData\",\n    \"baseUrl\": \"https://jsonplaceholder.typicode.com/todos\",\n    \"name\": \"{{e2e_source_object_name}}\"\n  }\n}"
        }
      }
    },
    {
      "name": "List E2E Assets",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/assets/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "assets", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{e2e_asset_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Create E2E Policy",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/policydefinitions",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "policydefinitions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\n    \"odrl\": \"http://www.w3.org/ns/odrl/2/\"\n  },\n  \"@id\": \"{{e2e_policy_id}}\",\n  \"policy\": {\n    \"@context\": \"http://www.w3.org/ns/odrl.jsonld\",\n    \"@type\": \"Set\",\n    \"permission\": [],\n    \"prohibition\": [],\n    \"obligation\": []\n  }\n}"
        }
      }
    },
    {
      "name": "List E2E Policies",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/policydefinitions/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "policydefinitions", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{e2e_policy_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Create E2E Contract Definition",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/contractdefinitions",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "contractdefinitions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"@id\": \"{{e2e_contract_definition_id}}\",\n  \"accessPolicyId\": \"{{e2e_policy_id}}\",\n  \"contractPolicyId\": \"{{e2e_policy_id}}\",\n  \"assetsSelector\": [\n    {\n      \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{e2e_asset_id}}\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "List E2E Contract Definitions",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{provider_jwt}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/management/v3/contractdefinitions/request",
          "host": ["{{provider}}", "{{dsDomain}}"],
          "path": ["management", "v3", "contractdefinitions", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"offset\": 0,\n  \"limit\": 1,\n  \"filterExpression\": [\n    {\n      \"operandLeft\": \"id\",\n      \"operator\": \"=\",\n      \"operandRight\": \"{{e2e_contract_definition_id}}\"\n    }\n  ]\n}"
        }
      }
    }
  ]
}
